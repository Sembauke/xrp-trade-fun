{
  "name": "xrp-trade-fun",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:server:btc\" \"vite\"",
    "dev:xrp": "concurrently \"npm:server\" \"vite\"",
    "server": "node server/index.js",
    "server:btc": "SYMBOL=BTCUSDT STARTING_CAPITAL=20000 DB_PATH=data/trading-btc.db PORT=8788 node server/index.js",
    "dev:btc": "concurrently \"npm:server:btc\" \"vite --port 5175\"",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "date-fns": "^3.3.1",
    "express": "^5.2.1",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.10.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.0"
  }
}
